# ── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/data_vault

# ── Auth / Security ─────────────────────────────────────────────
JWT_SECRET=replace_with_32_char_random_string
HMAC_SECRET=replace_with_32_char_random_string_for_qr

# ── Server ───────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── AWS S3 (photo storage) ───────────────────────────────────────
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
S3_BUCKET=carbon-clarity-field-photos

# ── Mobile Money ─────────────────────────────────────────────────
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_API_KEY=your_mtn_api_key
MTN_MOMO_SUBSCRIPTION_KEY=your_subscription_key
TELECEL_API_BASE_URL=https://api.telecelgh.com
TELECEL_API_KEY=your_telecel_api_key

# ── Frontend (Vite) ──────────────────────────────────────────────
VITE_API_URL=http://localhost:4000
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
